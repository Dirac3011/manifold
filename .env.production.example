# Copy to .env on your DigitalOcean droplet:
#   cp .env.production.example .env

# --- Public URL (required) ---
# Use https://your-domain.com once Caddy has HTTPS, or http://DROPLET_IP for initial testing
NEXTAUTH_URL="https://your-domain.example.com"
NEXTAUTH_SECRET="generate-a-long-random-string"

# --- Database (used by docker-compose.prod.yml) ---
POSTGRES_USER=manifold
POSTGRES_PASSWORD="change-me-strong-password"
POSTGRES_DB=manifold

# DATABASE_URL is set automatically in docker-compose.prod.yml for the app container.
# Only set manually if deploying without Compose:
# DATABASE_URL="postgresql://manifold:password@postgres:5432/manifold?schema=public"

# --- OAuth (optional; update callback URLs to your public domain) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# --- Email invites (optional; use Resend SMTP or similar) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Manifold <noreply@your-domain.example.com>"

# --- Misc ---
CROSSREF_MAILTO="you@example.com"
LATEX_DOCKER_IMAGE="manifold-latex"
# Host path for LaTeX compile temp files (must match bind mount in docker-compose.prod.yml)
COMPILE_WORKSPACE_HOST="/opt/manifold/compile-workspace"
COMPILE_TIMEOUT_MS=120000
COMPILE_MAX_OUTPUT_BYTES=10485760
