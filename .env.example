# Database
DATABASE_URL="postgresql://manifold:manifold@localhost:5432/manifold?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-in-production"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# CrossRef polite pool (optional, improves DOI lookup rate limits)
CROSSREF_MAILTO="you@example.com"

# LaTeX compilation
LATEX_DOCKER_IMAGE="manifold-latex"
COMPILE_TIMEOUT_MS=120000
COMPILE_MAX_OUTPUT_BYTES=10485760

# Storage paths (relative to project root)
STORAGE_PATH="./storage"
COMPILE_WORKSPACE="./compile-workspace"
